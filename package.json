{
  "name": "mcpscraper-sdk-monorepo",
  "private": true,
  "version": "0.0.0",
  "description": "Public client SDKs and API contracts for mcpscraper.dev and memory.mcpscraper.dev",
  "workspaces": [
    "packages/memory",
    "packages/scraper",
    "packages/cli"
  ],
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "npm run build --workspaces",
    "typecheck": "npm run typecheck --workspaces",
    "test": "npm run test --workspaces",
    "test:python": "cd packages/scraper-python && uv run pytest && cd ../memory-python && uv run pytest",
    "validate-contracts": "tsx scripts/validate-contracts.ts",
    "smoke-test": "tsx scripts/smoke-test.ts",
    "generate:memory": "tsx scripts/generate-memory-client.ts",
    "update:memory-contract": "tsx scripts/update-memory-manifest.ts"
  },
  "devDependencies": {
    "typescript": "^5.6.0",
    "tsx": "^4.19.0",
    "tsup": "^8.3.0",
    "json-schema-to-typescript": "^15.0.4"
  },
  "overrides": {
    "esbuild": "^0.28.1"
  }
}
