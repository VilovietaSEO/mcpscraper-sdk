{
  "name": "mcpscraper-sdk",
  "version": "0.16.0",
  "description": "Official Node.js client for all 165 mcpscraper.dev MCP tools and the REST API",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "prepack": "npm run build",
    "generate": "openapi-typescript ../../contracts/scraper.openapi.yaml -o src/schema.ts",
    "build": "tsup src/index.ts --format esm,cjs --dts",
    "typecheck": "tsc --noEmit",
    "test": "tsx --test test/*.test.ts"
  },
  "keywords": [
    "mcp-scraper",
    "serp",
    "web-scraping",
    "seo-api"
  ],
  "dependencies": {
    "mcpscraper-memory-sdk": "^0.15.0"
  },
  "devDependencies": {
    "openapi-typescript": "^7.13.0"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/VilovietaSEO/mcpscraper-sdk.git",
    "directory": "packages/scraper"
  },
  "publishConfig": {
    "access": "public"
  }
}
