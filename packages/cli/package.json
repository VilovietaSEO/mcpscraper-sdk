{
  "name": "mcpscraper-cli",
  "version": "0.1.0",
  "description": "Command-line interface for mcpscraper.dev and memory.mcpscraper.dev",
  "license": "MIT",
  "type": "module",
  "bin": {
    "mcpscraper": "dist/bin/cli.js"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsup src/cli.ts --format esm --out-dir dist/bin",
    "typecheck": "tsc --noEmit",
    "test": "tsx --test test/*.test.ts"
  },
  "dependencies": {
    "mcpscraper-sdk": "^0.2.0",
    "mcpscraper-memory-sdk": "^0.1.0",
    "commander": "^12.0.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/VilovietaSEO/mcpscraper-sdk.git",
    "directory": "packages/cli"
  },
  "publishConfig": {
    "access": "public"
  }
}
